# 🔑 Google Ads API Configuration (Required)
# Customer ID (10 digits) - Find in top right corner of Google Ads
GOOGLE_ADS_CUSTOMER_ID=1234567890

# Developer Token - Get from API Center in Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# OAuth Details - Get from Google Cloud Console
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# Manager Account (if using MCC)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_manager_account_id

# 🤖 OpenAI Configuration (Required)
# API Key - Get from platform.openai.com (starts with sk-)
OPENAI_API_KEY=sk-your_openai_key_here

# 🔧 Google Ads API Settings
GOOGLE_ADS_USE_PROTO_PLUS=True

# 📧 Email Configuration (Optional - for reports)
SENDER_EMAIL=your_email@domain.com
SENDER_PASSWORD=your_email_password
RECIPIENT_EMAIL=recipient@domain.com

# 🏢 Business Configuration
BUSINESS_NAME=Air Cleaning Tech LLC
BUSINESS_PHONE=2108730584
TARGET_LOCATION=San Antonio, TX
CAMPAIGN_DAILY_BUDGET=50

# 🖼️ Landing Page Configuration
PEXELS_API_KEY=your_pexels_api_key_here

# 🌐 Webhook Configuration
WEBHOOK_PORT=5000
WEBHOOK_HOST=localhost

# 📊 Reporting Configuration
REPORT_FREQUENCY=daily
OPTIMIZATION_INTERVAL_HOURS=10
